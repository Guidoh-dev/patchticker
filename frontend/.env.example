# ─────────────────────────────────────────────────────────────────────────────
# PatchTicker Frontend — Environment Variables
#
# HOW TO USE
#   cp .env.example .env
#   Fill in the VITE_* values before running `npm run dev` or `npm run build`.
#
# SECURITY
#   Only VITE_* prefixed variables are exposed to the browser bundle.
#   Server-side secrets (STRIPE_SECRET_KEY, JWT_*, CSRF_*, DB_*) must NEVER
#   be placed here — they belong in backend/.env only.
# ─────────────────────────────────────────────────────────────────────────────

# ── Stripe — PUBLIC keys only ─────────────────────────────────────────────────
# The publishable key is safe to expose in the frontend (cannot make charges).
# Get from: https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_WITH_YOUR_PUBLISHABLE_KEY

# Stripe Price IDs for the Pro tier (create in Stripe Dashboard → Products)
# These are shown to users on the pricing page and sent to the backend checkout endpoint.
VITE_STRIPE_PRICE_MONTHLY=price_REPLACE_WITH_monthly_price_id
VITE_STRIPE_PRICE_ANNUAL=price_REPLACE_WITH_annual_price_id

# ── App URL ────────────────────────────────────────────────────────────────────
# Used for absolute links. Set to your production domain in CI/CD.
VITE_APP_URL=http://localhost:3000

# ── hCaptcha — PUBLIC site key only ───────────────────────────────────────────
# Safe to expose in frontend. The secret key lives in backend/.env only.
# Get from: https://dashboard.hcaptcha.com → Sites → your site → Settings
VITE_HCAPTCHA_SITE_KEY=6d344ff4-6e74-4b64-b356-bc7a18f00b0c
