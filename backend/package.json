{
  "name": "patchticker-backend",
  "version": "1.0.0",
  "private": true,
  "main": "src/server.js",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "lint": "eslint src/",
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --watch",
    "audit:check": "npm audit --audit-level=moderate",
    "audit:fix": "npm audit fix",
    "audit:report": "npm audit --json > audit-report.json && echo 'Audit report saved to audit-report.json'"
  },
  "dependencies": {
    "argon2": "0.44.0",
    "axios": "1.9.0",
    "cookie-parser": "1.4.7",
    "cors": "2.8.5",
    "csrf-csrf": "4.0.3",
    "dotenv": "16.5.0",
    "express": "4.21.2",
    "express-rate-limit": "7.5.0",
    "helmet": "8.3.0",
    "jsonwebtoken": "9.0.3",
    "morgan": "1.10.0",
    "uuid": "11.1.0",
    "winston": "3.19.0",
    "winston-daily-rotate-file": "5.0.0",
    "zod": "3.24.2",
    "pg": "8.13.3",
    "stripe": "17.7.0",
    "nodemailer": "6.9.16",
    "node-cron": "3.0.3",
    "cheerio": "1.0.0"
  },
  "devDependencies": {
    "eslint": "9.27.0",
    "jest": "29.7.0",
    "nodemon": "3.1.10",
    "supertest": "7.1.0",
    "@eslint/js": "9.27.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/*.test.js"
    ]
  }
}
