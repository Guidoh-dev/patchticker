# ─────────────────────────────────────────────────────────────────────────────
# PatchTicker — Environment Configuration
#
# HOW TO USE
# ───────────
#   cp .env.example .env
#   # Edit .env and fill in every REPLACE_WITH_* value before starting the server.
#   # NEVER commit .env to version control.
#
# GENERATING SECRETS
# ───────────────────
#   JWT secrets (64 bytes):
#     node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
#
#   CSRF secret (32 bytes):
#     node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
#   All three secrets must be different values.
#
# SECRET ROTATION
# ────────────────
#   To rotate a secret without restarting the server:
#     1. Copy the current secret value into the _PREV variable below.
#     2. Generate a new secret and put it in the main variable.
#     3. Send SIGUSR2 to the server process:
#          kill -USR2 $(cat .pid)
#     4. The server accepts tokens from both secrets for ROTATION_OVERLAP_MS
#        (default 30 minutes), then drops the old one automatically.
#     5. After the overlap window, remove the _PREV value and rotate again
#        if needed.
#
# REQUIRED IN PRODUCTION (server refuses to start if missing or placeholder)
#   JWT_ACCESS_SECRET, JWT_REFRESH_SECRET, CSRF_SECRET, ALLOWED_ORIGINS
# ─────────────────────────────────────────────────────────────────────────────


# ── Server ────────────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=4000

# Number of reverse proxies in front of this server.
# Affects how req.ip is resolved from X-Forwarded-For.
#
# VALUES:
#   0 or false          → direct connection, no proxy (dev only)
#   1                   → one proxy hop (typical: Nginx → Node)
#   2+                  → multiple proxy hops
#   'cloudflare'        → behind Cloudflare; enables CF-Connecting-IP extraction
#                         (recommended when CLOUDFLARE_MODE=true)
#   'loopback'          → trust only loopback range (RFC-1918 VPC deployments)
TRUST_PROXY=1


# ── Server binding ───────────────────────────────────────────────────────────
#
# BIND_HOST controls which network interface Node listens on.
#
# '127.0.0.1' — loopback only (default in production).
#               Node is unreachable from the public internet.
#               Requires a reverse proxy (Nginx/Caddy) forwarding to this port.
#               Correct setup: Cloudflare → Nginx (443) → Node (127.0.0.1:4000)
#
# '0.0.0.0'   — all interfaces (default in dev/test).
#               Node is directly reachable — only use if behind a cloud LB
#               with no Nginx layer, or for local development.
#
# Override only if your deployment topology requires it.
# In production, leave unset to get the safe '127.0.0.1' default.
BIND_HOST=127.0.0.1

# ── Cloudflare ────────────────────────────────────────────────────────────────

# Set to true when your origin sits behind Cloudflare (any plan).
# When enabled:
#   • CF-Connecting-IP is used as the authoritative real client IP
#     (cannot be spoofed by clients, unlike X-Forwarded-For)
#   • CF-Visitor JSON is parsed for HTTPS scheme detection
#   • req.cloudflare is attached with country/ray-id metadata for logging
#   • CLOUDFLARE_VALIDATE_IPS enforcement is available (see below)
# When false: all Cloudflare-specific logic is a transparent no-op.
CLOUDFLARE_MODE=false

# Reject requests that do NOT arrive from a known Cloudflare IP range.
# Requires CLOUDFLARE_MODE=true. Blocks direct-to-origin access.
#
# ⚠ ONLY enable after:
#   1. All legitimate traffic flows through Cloudflare (no direct hits)
#   2. Your firewall/security-group already restricts inbound to CF IPs
#   3. Health checks are whitelisted at the network layer
#
# Enabling prematurely will break uptime monitors and load balancer probes.
CLOUDFLARE_VALIDATE_IPS=false

# Override the built-in Cloudflare IP range list with a JSON array of CIDRs.
# Useful when you manage your own CF IP refresh cron job.
# Leave empty to use the built-in list (updated Dec 2024).
# Format: '["103.21.244.0/22","104.16.0.0/13"]'
CLOUDFLARE_IP_RANGES=


# ── CORS ──────────────────────────────────────────────────────────────────────

# Comma-separated list of allowed frontend origins.
# All must use HTTPS in production.
# Example: https://patchticker.app,https://www.patchticker.app
ALLOWED_ORIGINS=http://localhost:3000


# ── HTTPS / HSTS ──────────────────────────────────────────────────────────────

# Force HTTP → HTTPS redirect. Set to true in production.
HTTPS_REDIRECT=false

# HSTS max-age in seconds. 31536000 = 1 year (required minimum for preload list).
# Increase to 63072000 (2 years) once the site is stable.
HSTS_MAX_AGE=31536000

# Set to true ONLY after submitting to https://hstspreload.org.
# Requires max-age >= 31536000 and includeSubDomains (always set).
HSTS_PRELOAD=false


# ── Content Security Policy ───────────────────────────────────────────────────

# URI for CSP violation reports. Leave empty to disable reporting.
# Example: https://your-csp-reporter.app/csp-report
CSP_REPORT_URI=


# ── JWT ───────────────────────────────────────────────────────────────────────

# Access token secret — used to sign short-lived JWTs (15 min default).
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Must be at least 64 hex characters (32 bytes). Must differ from REFRESH secret.
JWT_ACCESS_SECRET=REPLACE_WITH_64_BYTE_HEX_SECRET

# Previous access secret — set this during rotation (see SECRET ROTATION above).
# Leave empty when not rotating.
JWT_ACCESS_SECRET_PREV=

# Refresh token secret — used to sign the HMAC in the refresh cookie store.
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Must be at least 64 hex characters. Must differ from ACCESS secret.
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_64_BYTE_HEX_SECRET

# Previous refresh secret — set during rotation. Leave empty when not rotating.
JWT_REFRESH_SECRET_PREV=

# Access token lifetime in seconds. Default: 900 (15 minutes).
JWT_ACCESS_EXPIRES_IN=900

# Refresh token lifetime in seconds. Default: 604800 (7 days).
JWT_REFRESH_EXPIRES_IN=604800


# ── CSRF ──────────────────────────────────────────────────────────────────────

# CSRF token HMAC secret — must differ from both JWT secrets.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be at least 32 hex characters (16 bytes).
CSRF_SECRET=REPLACE_WITH_32_BYTE_HEX_SECRET

# Previous CSRF secret — set during rotation. Leave empty when not rotating.
CSRF_SECRET_PREV=


# ── CAPTCHA (hCaptcha) ───────────────────────────────────────────────────────

# Server-side secret key from https://dashboard.hcaptcha.com
# Required in production. Server refuses to start without it (unless HCAPTCHA_ENABLED=false).
# Generate: sign up at hcaptcha.com → Sites → Add New Site → copy Secret Key
HCAPTCHA_SECRET_KEY=REPLACE_WITH_hcaptcha_secret_key

# Public site key — passed to the frontend via Vite (VITE_HCAPTCHA_SITE_KEY)
HCAPTCHA_SITE_KEY=REPLACE_WITH_hcaptcha_site_key

# Minimum score to pass (0.0–1.0). hCaptcha Enterprise only; standard returns 1.0.
HCAPTCHA_MIN_SCORE=0.5

# Set to 'false' to disable CAPTCHA globally (E2E tests, dev without hCaptcha account).
HCAPTCHA_ENABLED=true


# ── Fraud detection ───────────────────────────────────────────────────────────

# Comma-separated list of additional email domains to block at registration.
# The built-in list covers ~100 known disposable providers.
# Example: tempinbox.net,guerrillamail.co
BLOCKED_EMAIL_DOMAINS=

# Sliding window for cross-account credential stuffing detection (ms).
# Default: 900000 (15 minutes)
STUFFING_WINDOW_MS=900000

# Number of unique accounts from one IP before AUTH_ABUSE signal fires.
# Default: 10
STUFFING_UNIQUE_THRESHOLD=10

# Re-fire AUTH_ABUSE signal every N additional unique accounts after threshold.
# Default: 5
STUFFING_SIGNAL_EVERY=5

# Per-user checkout session limit per hour (card-testing defence).
# Controlled by checkoutLimiter in rateLimiter.js.
# Configured in code (default 5/hr). Override not exposed as env var — change in code.


# ── Secret rotation ───────────────────────────────────────────────────────────

# How long (ms) the previous secret stays valid after rotation.
# Default: 1800000 (30 minutes). Must be >= JWT_ACCESS_EXPIRES_IN to avoid
# logging users out mid-session during rotation.
ROTATION_OVERLAP_MS=1800000

# Automatic rotation interval in ms. Set to 0 to disable.
# Pair with a secrets manager that updates env vars on a schedule.
# Minimum allowed value: 60000 (1 minute). Example: 86400000 = 24 hours.
SECRET_AUTO_ROTATE_MS=0


# ── Account lockout ───────────────────────────────────────────────────────────

LOCKOUT_MAX_ATTEMPTS=5
LOCKOUT_DURATION_SECONDS=900


# ── Rate limiting ─────────────────────────────────────────────────────────────

# Base rate limit window in ms. Default: 900000 (15 minutes).
RATE_WINDOW_MS=900000

# Maximum exponential backoff window in ms. Default: 57600000 (16 hours).
BACKOFF_MAX_MS=57600000

# Backoff multiplier per offence. Default: 2 (doubles each offence).
BACKOFF_MULTIPLIER=2


# ── IP abuse detection ────────────────────────────────────────────────────────

# Abuse point threshold that triggers automatic IP blacklisting.
# Signal weights: RATE_LIMIT_HIT=1  GUARD_REJECTION=3  AUTH_ABUSE=4
#                 SUSPICIOUS=5      SCANNER=8
# Default: 20
AUTO_BLACKLIST_POINTS=20

# Auto-blacklist entry TTL in ms. Default: 86400000 (24 hours).
AUTO_BLACKLIST_TTL_MS=86400000

# IP abuse record decay window in ms. Default: 86400000 (24 hours).
# An IP that goes quiet for this long starts with a clean record.
ABUSE_DECAY_MS=86400000

# Number of 4xx responses from one IP within 5 minutes before a SUSPICIOUS
# signal fires. Default: 20.
CLIENT_ERR_THRESHOLD=20

# Response time in ms above which a slow-response warning is logged.
# Default: 2000 (2 seconds).
SLOW_RESPONSE_MS=2000

# Comma-separated CIDR ranges to block at startup.
# Example: 10.0.0.0/8,198.51.100.0/24
# Leave empty in development.
BLOCKED_CIDRS=


# ── Reddit API (optional) ─────────────────────────────────────────────────────
# Server runs without Reddit integration if these are empty.
# Create a "script" app at https://www.reddit.com/prefs/apps

REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=PatchTicker/1.0 by YourUsername


# ── Logging ───────────────────────────────────────────────────────────────────

# Minimum log level: error | warn | info | http | debug
LOG_LEVEL=info

# Directory for rotating log files (relative to backend/).
LOG_DIR=./logs


# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string. Never expose port 5432 to the internet.
# Use the private network address on Railway, Supabase, Neon, RDS, etc.
#
# Format: postgres://user:password@host:5432/dbname?sslmode=require
#
# The application connects as the patchticker_app role (least-privilege).
# Run schema.sql once as patchticker_owner to create tables and grant permissions.
#   psql "$DATABASE_URL" -f schema.sql
DATABASE_URL=

# Force SSL on the DB connection. Always true in production.
# Set to true in development if your local DB uses SSL.
DB_SSL=false

# Path to the database server's CA certificate for full chain verification.
# Strongly recommended in production to prevent MITM attacks on the DB connection.
# Example: /etc/ssl/patchticker-db-ca.pem
# Leave empty to require SSL without CA verification (acceptable on private VPCs).
DB_SSL_CA=

# Connection pool settings
DB_POOL_MAX=10                # max connections in pool
DB_POOL_MIN=2                 # min idle connections
DB_IDLE_MS=30000              # release idle connection after 30 seconds
DB_CONN_TIMEOUT_MS=5000       # fail if can't acquire connection within 5 seconds
DB_STATEMENT_TIMEOUT_MS=30000 # kill any query running longer than 30 seconds


# ── Field-level encryption ────────────────────────────────────────────────────
# AES-256-GCM key for encrypting PII stored in the database (emails, free text).
# Protects data at rest — if the DB is breached without this key, data is unreadable.
#
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be exactly 64 hex characters (32 bytes).
# Must differ from JWT and CSRF secrets.
#
# KEY ROTATION NOTE: AES-GCM keys cannot be hot-rotated like JWT secrets.
# Rotation requires a migration: read rows, decrypt with old key,
# re-encrypt with new key, update. Run inside a DB transaction.
DB_ENCRYPTION_KEY=REPLACE_WITH_64_BYTE_HEX_KEY


# ── Structured logging ────────────────────────────────────────────────────────
# Log level: error | warn | info | http | debug  (default: info)
# Set to 'debug' in development for verbose output.
# Never set to 'debug' in production — it logs request bodies.
LOG_LEVEL=info

# Directory for rotating log files (relative to backend/).
# Created automatically on startup if it doesn't exist.
# Files: error-YYYY-MM-DD.log, security-YYYY-MM-DD.log, combined-YYYY-MM-DD.log
LOG_DIR=./logs


# ── External log shipping — Logtail / Better Stack ────────────────────────────
# Ship all logs (info+) to Better Stack (https://betterstack.com/logs).
# 1. Create a source in Better Stack → Logs
# 2. Copy the Source Token here
# Leave blank to disable (logs still go to local files).
LOGTAIL_TOKEN=


# ── Error tracking — Sentry ───────────────────────────────────────────────────
# Ship error-level log entries to Sentry as events (no SDK required).
# 1. Create a project at https://sentry.io  (Platform: Node.js)
# 2. Copy the DSN from Project → Settings → Client Keys
# Format: https://<key>@<host>/sentry/<project_id>
# Leave blank to disable.
SENTRY_DSN=


# ── Alerting webhooks ─────────────────────────────────────────────────────────
# Fires on: server crashes, startup failures, 5xx spikes, rate-limit spikes,
#           auto-blacklist spikes, auth abuse spikes, DB connection errors.
#
# ALERT_WEBHOOK_TYPE: 'slack' | 'pagerduty' | 'generic'  (default: generic)
# Leave ALERT_WEBHOOK_URL blank to disable webhook dispatching.
# Alerts are always written to logs regardless of webhook config.

# Slack: create an Incoming Webhook at https://api.slack.com/messaging/webhooks
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_TYPE=slack

# PagerDuty: only needed when ALERT_WEBHOOK_TYPE=pagerduty
# Create an "Events v2 API" integration in your PagerDuty service.
# ALERT_WEBHOOK_URL=https://events.pagerduty.com/v2/enqueue
ALERT_PAGERDUTY_KEY=


# ── Spike detection thresholds ────────────────────────────────────────────────
# Tune these to match your traffic. Defaults are conservative.
#
# ALERT_THRESHOLD_5XX        — fire alert after N 5xx responses in 2 minutes  (default: 10)
# ALERT_THRESHOLD_BLACKLIST  — fire alert after N auto-blacklist events in 5 min (default: 5)
# ALERT_THRESHOLD_AUTH_ABUSE — fire alert after N failed-login events in 5 min (default: 20)
# ALERT_THRESHOLD_RATE_LIMIT — fire alert after N rate-limit hits in 1 minute  (default: 50)
ALERT_THRESHOLD_5XX=10
ALERT_THRESHOLD_BLACKLIST=5
ALERT_THRESHOLD_AUTH_ABUSE=20
ALERT_THRESHOLD_RATE_LIMIT=50


# ── Health endpoint authentication ────────────────────────────────────────────
# Protects /api/health/ready and /api/health/alerts in production.
# Pass as: X-Health-Secret: <value>
# Used by ops dashboards, uptime monitors, Kubernetes readiness probes.
# Generate: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
HEALTH_SECRET=REPLACE_WITH_48_CHAR_HEX_SECRET


# ── Stripe ────────────────────────────────────────────────────────────────────
# Live keys from https://dashboard.stripe.com/apikeys
# Use sk_test_xxx / pk_test_xxx during development.

# Server-side secret key. NEVER expose this to the frontend.
STRIPE_SECRET_KEY=REPLACE_WITH_sk_live_or_sk_test_key

# Webhook signing secret from Stripe Dashboard → Webhooks → your endpoint → Signing secret.
# Or use the Stripe CLI: stripe listen --forward-to localhost:4000/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=REPLACE_WITH_whsec_key

# Public key (used by frontend Stripe.js to tokenise card data).
STRIPE_PUBLISHABLE_KEY=REPLACE_WITH_pk_live_or_pk_test_key

# Price IDs for your subscription tiers (create in Stripe Dashboard → Products).
STRIPE_PRICE_PRO_MONTHLY=price_REPLACE_WITH_monthly_price_id
STRIPE_PRICE_PRO_ANNUAL=price_REPLACE_WITH_annual_price_id

# Optional: trial period for new subscribers (in days). Set to 0 to disable.
STRIPE_TRIAL_DAYS=5


# ── Application URL ───────────────────────────────────────────────────────────
# Used in email links and Stripe redirect URLs.
APP_URL=http://localhost:3000


# ── Email ─────────────────────────────────────────────────────────────────────
# Transport selection (in priority order):
#   1. BREVO_SMTP_KEY set   → Brevo SMTP relay (recommended free launch option)
#   2. SENDGRID_API_KEY set → SendGrid SMTP relay
#   3. SMTP_HOST set        → custom SMTP
#   4. Neither              → Ethereal test account (dev only, not delivered)

# From address shown in emails. Verify this sender/domain in Brevo before launch.
EMAIL_FROM_NAME=PatchTicker
EMAIL_FROM_ADDRESS=noreply@patchticker.app

# Option 1: Brevo SMTP — free tier friendly.
# Brevo → SMTP & API → SMTP tab:
#   BREVO_SMTP_LOGIN = SMTP login shown by Brevo
#   BREVO_SMTP_KEY   = generated SMTP key, not your Brevo account password
# Add Brevo SPF/DKIM/domain verification DNS records in Cloudflare, then use
# Admin → Pipeline → Send test email.
BREVO_SMTP_LOGIN=
BREVO_SMTP_KEY=
BREVO_SMTP_PORT=587

# Option 2: SendGrid SMTP relay
# SMTP relay uses host=smtp.sendgrid.net, port=587, username=apikey, password=SENDGRID_API_KEY.
SENDGRID_API_KEY=

# Option 3: Custom SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=


# ── Anthropic AI (AI-powered changelog summaries & scoring) ──────────────────
# Get your key at https://console.anthropic.com/settings/keys
# Used by the AI analysis service to generate verdicts, reasoning, and scores.
# Leave blank to disable AI features (static data fallback will be used).
ANTHROPIC_API_KEY=

# ── Expanded game/platform tracking ───────────────────────────────────────────
# Steam App tracking powers Pro "Follow my games" and live game patch ingestion.
# Steam App IDs are public identifiers; the Web API key is optional for richer
# metadata later, while RSS app news works with just the IDs.
STEAM_WEB_API_KEY=
STEAM_TRACKED_APP_IDS=730,553850,108694,1172470,570,252490,271590,1245620

# Discord status/client signal. RSS URL is public; override only if needed.
DISCORD_STATUS_RSS_URL=https://discordstatus.com/history.rss

# Battle.net and GOG currently use public support/news pages. No API keys needed.
BATTLENET_TRACKING_ENABLED=true
GOG_TRACKING_ENABLED=true

# Pipeline reliability controls
# Retry failed scraper detectors before marking a source unavailable.
SCRAPER_RETRY_ATTEMPTS=2
SCRAPER_RETRY_BACKOFF_MS=750

# Keep concurrency moderate to avoid source rate limits/403s.
PIPELINE_CONCURRENCY=4
